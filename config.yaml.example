# OpenClaw Agent Harness 配置文件
#
# 使用方法:
#   1. 复制此文件为 config.yaml
#   2. 填入你的 API Key（或使用环境变量）
#   3. 在代码中加载: load_provider_from_yaml("config.yaml")

# 默认 Provider（启动时使用）
default_provider: doubao

# 可用的 Provider 配置
providers:
  # Anthropic Claude
  claude:
    type: claude
    api_key: "${ANTHROPIC_API_KEY}"
    model: claude-opus-4-5
    # thinking_enabled: false  # 可选：启用 Extended Thinking
    # thinking_budget_tokens: 10000  # 可选：thinking token 预算

  # OpenAI
  openai:
    type: openai
    api_key: "${OPENAI_API_KEY}"
    model: gpt-4o
    base_url: "https://api.openai.com/v1"

  # 豆包（ByteDance）
  doubao:
    type: doubao
    api_key: "${DOUBAO_API_KEY}"
    model: doubao-pro-32k

  # 通义千问（阿里云）
  qwen:
    type: qwen
    api_key: "${DASHSCOPE_API_KEY}"
    model: qwen-max

  # DeepSeek
  deepseek:
    type: deepseek
    api_key: "${DEEPSEEK_API_KEY}"
    model: deepseek-chat

# Agent 配置
agent:
  max_turns: 50
  max_tokens_per_turn: 8192
  token_budget: 100000  # 可选：总 token 预算上限

# 工作目录
workspace: "."
